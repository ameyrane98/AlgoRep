{
  "manifest_version": 3,
  "name": "AlgoRep",
  "description": "AI-powered LeetCode learning system - sync solutions to GitHub with spaced repetition, complexity analysis, and study plan tracking",
  "homepage_url": "https://github.com/ameyrane98/AlgoRep",
  "version": "__LH_VERSION__",
  "author": "Amey Rane",
  "action": {
    "default_icon": "assets/thumbnail.png",
    "default_popup": "popup.html",
    "default_title": "AlgoRep - Your LeetCode learning system"
  },
  "icons": {
    "16": "assets/thumbnail.png",
    "48": "assets/thumbnail.png",
    "128": "assets/thumbnail.png"
  },
  "background": {
    "scripts": ["scripts/background.js"]
  },
  "permissions": ["unlimitedStorage", "storage", "webNavigation"],
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/*"],
      "js": ["scripts/leetcode.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://github.com/*"],
      "js": ["scripts/authorize.js"]
    },
    {
      "matches": ["https://practice.geeksforgeeks.org/*"],
      "js": ["scripts/gfg.js"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": ["data/studyPlans.json"],
      "matches": ["<all_urls>"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "algorep@algorep.dev",
      "strict_min_version": "109.0"
    }
  }
}
